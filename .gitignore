# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# playwright mcp session artifacts
.playwright-mcp/

# screenshots taken at repo root for visual review
/*.png

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
